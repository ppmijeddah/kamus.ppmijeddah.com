{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run init && next build && npm run init:db",
    "build:deploy": "NEXT_PUBLIC_IS_DEPLOYED=true npm run build",
    "dev": "npm run init && npm run init:db && next dev --turbopack",
    "init": "node ./scripts/validate-dictionary.js && node ./scripts/init-environment.js",
    "init:db": "node ./scripts/upsert-uuid-to-dictionary-csv.js && node ./scripts/init-database.js",
    "lint": "next lint",
    "start": "next start",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.76.1",
    "@tanstack/react-query-devtools": "^5.76.1",
    "@tanstack/react-virtual": "^3.13.9",
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.475.0",
    "motion": "^12.12.1",
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/typography": "^0.5.16",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "uuid": "^11.1.0"
  }
}
